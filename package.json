{
  "name": "blinkdisk",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "lint": "turbo run lint",
    "dev": "dotenv -- turbo run dev",
    "format": "biome format --write .",
    "env:update": "turbo run env:update",
    "db:migrate:dev": "dotenv -- pnpm --filter db migrate:dev",
    "db:migrate:prod": "dotenv -- pnpm --filter db migrate:prod",
    "db:studio": "dotenv -- pnpm --filter db studio",
    "emails:studio": "dotenv -- pnpm --filter emails studio",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "unused": "knip",
    "check": "biome check ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "dotenv-cli": "^8.0.0",
    "knip": "^5.82.1",
    "turbo": "^2.4.4",
    "typescript": "5.8.2"
  },
  "packageManager": "pnpm@8.15.6",
  "engines": {
    "node": ">=22"
  },
  "pnpm": {
    "overrides": {
      "esbuild": "0.25.3",
      "wrangler>esbuild": "0.27.3"
    }
  }
}
