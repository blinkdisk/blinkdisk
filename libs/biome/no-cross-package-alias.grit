    )
  },
  `import $_ from $source` where {
    not $filename <: includes "libs/schemas/",
    $source <: or { `"@schemas"`, includes "@schemas/" },
    register_diagnostic(
      span = $source,
      message = "Use @blinkdisk/schemas instead of @schemas. Path aliases are only for same-package imports."
    )
  },
  `import $_ from $source` where {
    not $filename <: includes "libs/config/",
    $source <: or { `"@config"`, includes "@config/" },
    register_diagnostic(
      span = $source,
      message = "Use @blinkdisk/config instead of @config. Path aliases are only for same-package imports."
    )
  },
  `import $_ from $source` where {
