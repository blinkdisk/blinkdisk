engine biome(1.0)
language js(typescript,jsx)

or {
  `import $_ from $source` where {
    not $filename <: includes "libs/ui/",
    $source <: or { `"@ui"`, includes "@ui/" },
    register_diagnostic(
      span = $source,
      message = "Use @blinkdisk/ui instead of @ui. Path aliases are only for same-package imports."
    )
  },
  `import $_ from $source` where {
    not $filename <: includes "apps/api/",
    $source <: or { `"@api"`, includes "@api/" },
    register_diagnostic(
      span = $source,
      message = "Use @blinkdisk/api instead of @api. Path aliases are only for same-package imports."
    )
  },
  `import $_ from $source` where {
