{
  "extends": "@blinkdisk/typescript/react.json",
  "compilerOptions": {
    "outDir": "dist",
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "baseUrl": "./src/",
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"],
}
