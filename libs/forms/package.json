{
  "name": "@blinkdisk/forms",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "lint": "eslint . --max-warnings 0",
    "check-types": "tsc --noEmit"
  },
  "imports": {
    "#*": [
      "./src/*",
      "./src/*.ts",
      "./src/*.tsx",
      "./src/*.js",
      "./src/*.jsx",
      "./src/*/index.ts",
      "./src/*/index.tsx",
      "./src/*/index.js",
      "./src/*/index.jsx"
    ]
  },
  "exports": {
    "./*": "./src/*.ts"
  },
  "devDependencies": {
    "@blinkdisk/eslint": "workspace:*",
    "@blinkdisk/typescript": "workspace:*",
    "@types/node": "^22.13.9",
    "@types/react": "19.0.10",
    "@types/react-dom": "19.0.4",
    "eslint": "^9.22.0",
    "typescript": "5.8.2"
  },
  "dependencies": {
    "@blinkdisk/schemas": "workspace:*",
    "@blinkdisk/ui": "workspace:*",
    "@blinkdisk/utils": "workspace:*",
    "@tanstack/react-form": "^1.27.1",
    "lucide-react": "^0.483.0"
  }
}
