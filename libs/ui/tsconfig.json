{
  "extends": "@blinkdisk/typescript/react.json",
  "compilerOptions": {
    "outDir": "dist",
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
  },
  "include": ["src", "../components/src/dynamic-field.tsx"],
  "exclude": ["node_modules", "dist"],
}
