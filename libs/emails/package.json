{
  "name": "@blinkdisk/emails",
  "version": "0.0.0",
  "private": true,
  "imports": {
    "#*": [
      "./src/*.ts",
      "./src/*.tsx",
      "./src/*.js",
      "./src/*.jsx",
      "./src/*/index.ts",
      "./src/*/index.tsx",
      "./src/*/index.js",
      "./src/*/index.jsx",
      "./src/*"
    ],
    "#components/*": "./src/components/*.tsx",
    "#hooks/*": "./src/hooks/*.ts"
  },
  "exports": {
    "./*": "./src/*.tsx"
  },
  "scripts": {
    "studio": "email dev --dir src/ --port 3001",
    "lint": "eslint . --max-warnings 0",
    "check-types": "tsc --noEmit"
  },
  "devDependencies": {
    "@blinkdisk/eslint": "workspace:*",
    "@blinkdisk/typescript": "workspace:*",
    "@types/node": "^22.13.9",
    "@types/react": "19.0.10",
    "eslint": "^9.22.0",
    "react-email": "^5.1.1",
    "typescript": "5.8.2"
  },
  "dependencies": {
    "@react-email/components": "^0.0.34",
    "react": "^19.0.0"
  }
}
