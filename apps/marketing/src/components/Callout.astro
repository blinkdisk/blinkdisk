---
import AlertTriangleIcon from "@lucide/astro/icons/triangle-alert";

type Variant = "warning" | "info";

type Props = {
  variant?: Variant;
  title?: string;
  class?: string;
};

const {
  variant = "warning",
  title = "Important",
  class: className,
} = Astro.props;

const variants: Record<
  Variant,
  {
    aside: string;
    marker: string;
    iconWrap: string;
    icon: string;
    title: string;
  }
> = {
  warning: {
    aside:
      "border-amber-500/25 bg-gradient-to-br from-amber-500/10 via-card to-card dark:from-yellow-500/20 dark:via-yellow-500/8 dark:to-card",
    marker: "from-amber-500 to-orange-500",
    iconWrap:
      "border-amber-500/20 bg-amber-500/10 text-amber-700 dark:text-amber-300",
    icon: "text-current",
    title: "text-amber-800 dark:text-amber-300",
  },
  info: {
    aside:
      "border-primary/25 bg-gradient-to-br from-primary/10 via-card to-card dark:from-primary/20 dark:via-primary/8 dark:to-card",
    marker: "from-primary to-primary/60",
    iconWrap: "border-primary/20 bg-primary/10 text-primary",
    icon: "text-current",
    title: "text-primary",
  },
};

const styles = variants[variant];
---

<aside
  class:list={[
    "not-prose relative my-8 overflow-hidden rounded-xl border shadow-sm",
    styles.aside,
    className,
  ]}
>
  <div
    class:list={[
      "absolute left-0 top-0 h-full w-1 bg-gradient-to-b",
      styles.marker,
    ]}
  >
  </div>
  <div class="grid gap-4 px-5 py-5 sm:grid-cols-[auto_1fr] sm:px-6">
    <div
      class:list={[
        "flex size-9 items-center justify-center rounded-lg border",
        styles.iconWrap,
      ]}
    >
      <AlertTriangleIcon class:list={["size-5", styles.icon]} />
    </div>
    <div>
      <p
        class:list={[
          "text-sm font-bold uppercase tracking-widest",
          styles.title,
        ]}
      >
        {title}
      </p>
      <div
        class="mt-2 space-y-3 text-[0.95rem] leading-relaxed text-foreground/80 [&_a]:text-foreground [&_a]:underline [&_a]:underline-offset-4"
      >
        <slot />
      </div>
    </div>
  </div>
</aside>
