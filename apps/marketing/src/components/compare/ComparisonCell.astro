---
import { formatCountryDisplay } from "@blinkdisk/constants/countries";
import type { NormalizedCellValue } from "@blinkdisk/utils/tools";
import CheckIcon from "@lucide/astro/icons/check";
import XIcon from "@lucide/astro/icons/x";

type Props = {
  value: NormalizedCellValue;
  valueType?: "country";
  srText?: { true: string; false: string; partial: string };
};

const { value, valueType, srText } = Astro.props;

const defaultSrText = {
  true: "Supported",
  false: "Not supported",
  partial: "Partially supported",
};
const finalSrText = srText ?? defaultSrText;
const stringValue =
  typeof value.value === "string" && valueType === "country"
    ? formatCountryDisplay(value.value)
    : value.value;
---

<td class="px-4 py-3 text-center">
  {
    value.value === null ? (
      <span class="text-muted-foreground text-sm">No data</span>
    ) : typeof value.value === "boolean" || value.value === "partial" ? (
      <div class="flex flex-col items-center gap-1">
        {value.value === true ? (
          <span class="inline-flex size-6 items-center justify-center rounded-full bg-green-500/10 text-green-600 dark:text-green-400">
            <CheckIcon class="size-4" />
            <span class="sr-only">{finalSrText.true}</span>
          </span>
        ) : value.value === false ? (
          <span class="inline-flex size-6 items-center justify-center rounded-full bg-red-500/10 text-red-600 dark:text-red-400">
            <XIcon class="size-4" />
            <span class="sr-only">{finalSrText.false}</span>
          </span>
        ) : (
          <span class="inline-flex size-6 items-center justify-center rounded-full bg-yellow-500/10 text-yellow-600 dark:text-yellow-400">
            <span aria-hidden="true" class="text-sm leading-none font-semibold">
              ~
            </span>
            <span class="sr-only">{finalSrText.partial}</span>
          </span>
        )}
        {value.note && (
          <span class="text-muted-foreground text-xs">{value.note}</span>
        )}
      </div>
    ) : (
      <div class="flex flex-col items-center gap-1">
        <span class="text-foreground text-sm font-medium">{stringValue}</span>
        {value.note && (
          <span class="text-muted-foreground text-xs">{value.note}</span>
        )}
      </div>
    )
  }
</td>
