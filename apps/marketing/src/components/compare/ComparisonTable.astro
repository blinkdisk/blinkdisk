---
import type { LabelConfig } from "@blinkdisk/constants/comparison";
import type {
  NormalizedBackupTool,
  NormalizedCellValue,
} from "@blinkdisk/utils/tools";
import ComparisonRow from "@marketing/components/compare/ComparisonRow.astro";

type Props = {
  tools: (NormalizedBackupTool | null)[];
  category: keyof Pick<
    NormalizedBackupTool,
    | "general"
    | "level"
    | "strategies"
    | "features"
    | "interface"
    | "privacy"
    | "platforms"
    | "storages"
  >;
  labels: Record<string, LabelConfig>;
};

const { tools, category, labels } = Astro.props;

const keys = Object.keys(labels) as (keyof typeof labels)[];
const labelColumnMinWidth = 220;
const toolColumnMinWidth = 180;
const tableMinWidth = `${labelColumnMinWidth + tools.length * toolColumnMinWidth}px`;
---

<table class="w-full border-collapse" style={`min-width: ${tableMinWidth};`}>
  <thead>
    <tr class="border-border border-b">
      <th style={`min-width: ${labelColumnMinWidth}px;`}></th>
      {
        tools.map((tool) => (
          <th
            class="text-foreground px-4 py-3 text-center text-sm font-semibold"
            style={`min-width: ${toolColumnMinWidth}px;`}
          >
            {tool ? (
              <a
                href={tool.website}
                target="_blank"
                rel="noopener noreferrer"
                class="hover:text-primary transition-colors"
              >
                {tool.name}
              </a>
            ) : (
              <span class="text-muted-foreground">—</span>
            )}
          </th>
        ))
      }
    </tr>
  </thead>
  <tbody>
    {
      keys.map((key) => (
        <ComparisonRow
          label={labels[key].text}
          labelLink={labels[key].link}
          labelDescription={labels[key].description}
          labelIcon={labels[key].icon}
          valueType={labels[key].valueType}
          srText={labels[key].srText}
          values={tools.map((tool) =>
            tool
              ? ((
                  (tool[category] ?? {}) as Record<string, NormalizedCellValue>
                )[key] ?? {
                  value: null,
                  note: null,
                })
              : {
                  value: null,
                  note: null,
                },
          )}
        />
      ))
    }
  </tbody>
</table>
