---
import ChevronDownIcon from "@lucide/astro/icons/chevron-down";

type Props = {
  faqs: { question: string; answer: string }[];
  class?: string;
};

const { faqs, class: className } = Astro.props;
---

<div
  class:list={[
    "blog-faq not-prose my-8 overflow-hidden rounded-lg border border-border bg-card",
    className,
  ]}
>
  {
    faqs.map((faq) => (
      <details class="group border-b border-border last:border-b-0">
        <summary class="flex w-full cursor-pointer list-none items-start justify-between gap-4 px-4 py-3 text-left sm:px-5">
          <span class="text-sm font-semibold leading-6 text-foreground">
            {faq.question}
          </span>
          <ChevronDownIcon class="mt-0.5 size-4 shrink-0 text-muted-foreground transition-transform duration-200 group-open:rotate-180" />
        </summary>
        <div class="faq-content grid grid-rows-[0fr] transition-[grid-template-rows] duration-300 ease-out group-open:grid-rows-[1fr]">
          <div class="overflow-hidden">
            <p class="px-4 pb-4 text-sm leading-6 text-muted-foreground sm:px-5">
              {faq.answer}
            </p>
          </div>
        </div>
      </details>
    ))
  }
</div>

<style>
  .blog-faq details summary::-webkit-details-marker {
    display: none;
  }

  .blog-faq details.closing .faq-content {
    grid-template-rows: 0fr !important;
  }
</style>

<script>
  document
    .querySelectorAll<HTMLDetailsElement>(".blog-faq details")
    .forEach((details) => {
      const summary = details.querySelector("summary");
      const content = details.querySelector(".faq-content");

      summary?.addEventListener("click", (e) => {
        if (details.open) {
          e.preventDefault();
          content?.addEventListener(
            "transitionend",
            () => {
              details.open = false;
            },
            { once: true },
          );
          details.classList.add("closing");
        }
      });

      details.addEventListener("toggle", () => {
        if (details.open) {
          details.classList.remove("closing");
        }
      });
    });
</script>
