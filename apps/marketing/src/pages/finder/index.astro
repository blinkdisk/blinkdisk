---
import DefaultLayout from "@marketing/layouts/DefaultLayout.astro";
import FinderIntro from "@marketing/components/finder/FinderIntro.astro";
import { BackupFinder } from "@marketing/components/finder/react/BackupFinder";
import { COMPARISON_TOOLS } from "@blinkdisk/constants/comparison";

// Show every tool on the finder regardless of `publishedAt` — the staggered
// release only gates the /compare/* sitemap, not discoverability here.
const sortedTools = [...COMPARISON_TOOLS].sort((a, b) =>
  a.name.localeCompare(b.name),
);

const title = "Backup Tool Finder: Find the Right Tool for Your Needs";
const description =
  "Filter backup tools by platform, storage, privacy, features, and pricing to find the one that matches your requirements. Compare matches side-by-side with BlinkDisk.";

const structuredData = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: title,
  description,
  mainEntity: {
    "@type": "ItemList",
    itemListElement: sortedTools.map((tool, index) => ({
      "@type": "SoftwareApplication",
      position: index + 1,
      name: tool.name,
      url: tool.website,
      applicationCategory: "Backup Software",
    })),
  },
};
---

<DefaultLayout
  title={title}
  description={description}
  structuredData={structuredData}
>
  <article class="mx-auto pt-page pb-page w-content">
    <FinderIntro title={title} description={description} />
    <BackupFinder client:load tools={sortedTools} />
  </article>
</DefaultLayout>
