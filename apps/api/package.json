{
  "name": "@blinkdisk/api",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "node env.js && wrangler dev --port=4000 -c ./wrangler.jsonc -c ../cloud/wrangler.jsonc --persist-to=../../.wrangler",
    "deploy": "tsc --noEmit && wrangler deploy --minify --var SENTRY_RELEASE:$(sentry-cli releases propose-version) --outdir dist",
    "postdeploy": "bash ./sentry.sh",
    "typecheck": "tsc --noEmit",
    "typegen": "wrangler types --env-interface CloudflareBindings",
    "env:update": "node env.js && pnpm run typegen",
    "lint": "eslint . --max-warnings=0"
  },
  "exports": {
    "./*": "./src/*.ts"
  },
  "devDependencies": {
    "@blinkdisk/eslint": "workspace:*",
    "@blinkdisk/typescript": "workspace:*",
    "@sentry/cli": "^3.3.0",
    "@types/node": "^22.13.9",
    "dotenv": "^16.4.7",
    "eslint": "^9.22.0",
    "typescript": "5.8.2",
    "wrangler": "^4.32.0"
  },
  "dependencies": {
    "@better-auth/electron": "1.5.5",
    "@blinkdisk/config": "workspace:*",
    "@blinkdisk/db": "workspace:*",
    "@blinkdisk/schemas": "workspace:*",
    "@blinkdisk/utils": "workspace:*",
    "@hono/trpc-server": "^0.4.0",
    "@polar-sh/sdk": "^0.35.4",
    "@sentry/cloudflare": "^10.42.0",
    "@trpc/server": "^10.45.2",
    "axios": "^1.13.2",
    "better-auth": "1.5.5",
    "hono": "^4.9.4",
    "kysely": "^0.27.6",
    "posthog-node": "^5.9.2",
    "zod": "^3.24.2"
  }
}
