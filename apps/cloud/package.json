{
  "name": "@blinkdisk/cloud",
  "type": "module",
  "scripts": {
    "dev": "node env.js && wrangler dev --port=4001 --inspector-port=4002 --persist-to=../../.wrangler",
    "deploy": "tsc --noEmit && wrangler deploy --minify --var SENTRY_RELEASE:$(sentry-cli releases propose-version) --outdir dist",
    "postdeploy": "bash ./sentry.sh",
    "typecheck": "tsc --noEmit",
    "typegen": "wrangler types --env-interface CloudflareBindings",
    "env:update": "node env.js && pnpm run typegen",
    "lint": "biome check ."
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.886.0",
    "@aws-sdk/s3-request-presigner": "^3.886.0",
    "@blinkdisk/constants": "workspace:*",
    "@blinkdisk/db": "workspace:*",
    "@blinkdisk/schemas": "workspace:*",
    "@blinkdisk/utils": "workspace:*",
    "@sentry/cloudflare": "^10.42.0"
  },
  "devDependencies": {
    "@blinkdisk/typescript": "workspace:*",
    "@sentry/cli": "^3.3.0",
    "dotenv": "^16.4.7",
    "wrangler": "^4.91.0"
  }
}
